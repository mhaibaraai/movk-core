{
  "name": "@movk/core",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.13.1",
  "description": "Modern Vue.js utilities and composables collection with TypeScript support",
  "author": "yixuan",
  "license": "MIT",
  "homepage": "https://github.com/mhaibaraai/movk-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhaibaraai/movk-core.git"
  },
  "bugs": {
    "url": "https://github.com/mhaibaraai/movk-core/issues"
  },
  "keywords": [
    "movk",
    "@movk/core",
    "tools"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp --commit --tag --push",
    "publish": "pnpm publish --access public --no-git-checks",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "up": "taze major -wIr",
    "clean": "find . -name 'node_modules' -type d -prune -execdir rm -rf '{}' +"
  },
  "peerDependencies": {
    "vue": "catalog:vue"
  },
  "dependencies": {
    "@vueuse/core": "catalog:vue",
    "zod": "catalog:runtime"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:quality",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:quality",
    "eslint-plugin-format": "catalog:quality",
    "lint-staged": "catalog:quality",
    "simple-git-hooks": "catalog:quality",
    "taze": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:types",
    "unbuild": "catalog:build",
    "vite": "catalog:build",
    "vitest": "catalog:quality"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
